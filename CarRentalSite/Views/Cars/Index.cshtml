@model IEnumerable<CarRentalSite.Models.Car>
@{
    ViewData["Title"] = "Автомобили";
}
<h2>Доступные автомобили</h2>
<div class="row">
    @foreach (var car in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <img src="@car.ImageUrl" class="card-img-top" alt="@car.Brand @car.Model" style="height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title">@car.Brand @car.Model (@car.Year)</h5>
                    <p class="card-text">@car.Description</p>
                    <p class="card-text"><strong>@car.PricePerDay ₽ / день</strong></p>
                    <a href="/Cars/Details/@car.Id" class="btn btn-outline-primary">Подробнее</a>
                </div>
            </div>
        </div>
    }
</div>