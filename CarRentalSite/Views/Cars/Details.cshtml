@model CarRentalSite.Models.Car
@{
    ViewData["Title"] = $"{Model.Brand} {Model.Model}";
    var success = Context.Request.Query.ContainsKey("success");
}

<div class="container mt-4">
    @if (success)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill"></i> ✅ Автомобиль успешно забронирован!
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/default-car.jpg" : Model.ImageUrl)"
                     class="img-fluid"
                     alt="@Model.Brand @Model.Model"
                     style="height: 400px; width: 100%; object-fit: cover;">
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 p-4 h-100">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-car-front-fill fs-1 text-danger"></i>
                    <h1 class="display-5 fw-bold text-danger mb-0">@Model.Brand @Model.Model</h1>
                </div>
                <p class="text-muted"><i class="bi bi-calendar"></i> Год выпуска: @Model.Year</p>
                <p class="lead">@Model.Description</p>
                <hr />
                <h3 class="text-danger fw-bold">@Model.PricePerDay ₽ <small class="text-muted fw-normal">/ день</small></h3>

                <div class="mt-4 d-flex flex-wrap gap-3">
                    @if (Model.IsAvailable)
                    {
                        if (User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Rentals" asp-action="Create" asp-route-carId="@Model.Id" class="btn btn-danger btn-lg rounded-pill px-4">
                                <i class="bi bi-calendar-check"></i> Забронировать онлайн
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-danger btn-lg rounded-pill px-4">
                                <i class="bi bi-box-arrow-in-right"></i> Войдите, чтобы бронировать
                            </a>
                        }
                        <button class="btn btn-outline-secondary btn-lg rounded-pill px-4" onclick="showPhone()">
                            <i class="bi bi-telephone"></i> Позвонить для аренды
                        </button>
                    }
                    else
                    {
                        <div class="alert alert-warning rounded-3 w-100">
                            <i class="bi bi-exclamation-triangle"></i> Автомобиль временно недоступен
                        </div>
                    }
                </div>
                <div class="mt-3">
                    <a asp-action="Index" class="btn btn-link text-danger text-decoration-none">
                        <i class="bi bi-arrow-left"></i> Вернуться к списку
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="phoneModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4">
            <div class="modal-header bg-danger text-white rounded-top-4">
                <h5 class="modal-title"><i class="bi bi-telephone"></i> 📞 Номер для аренды</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <h3 class="mb-3 text-danger">+7 (999) 123-45-67</h3>
                <p class="text-muted">Звоните с 9:00 до 21:00, без выходных</p>
                <a href="tel:+79991234567" class="btn btn-danger rounded-pill px-4"><i class="bi bi-telephone-forward"></i> Позвонить сейчас</a>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

<script>
    function showPhone() {
        var myModal = new bootstrap.Modal(document.getElementById('phoneModal'));
        myModal.show();
    }
</script>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}