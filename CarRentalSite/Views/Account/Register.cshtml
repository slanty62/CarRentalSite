@model CarRentalSite.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CarRental</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
            /* Небольшое изменение градиента для страницы регистрации */
            .auth-body {
                background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            }

            .auth-card .btn-primary {
                background: linear-gradient(90deg, #f093fb 0%, #f5576c 100%);
            }

                .auth-card .btn-primary:hover {
                    background: linear-gradient(90deg, #e07bcb 0%, #e8455a 100%);
                }
    </style>
</head>
<body class="auth-body">
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="col-md-6 col-lg-5">
            <div class="card auth-card">
                <div class="card-header">
                    <i class="bi bi-person-plus auth-icon" style="color: #f5576c;"></i>
                    <h3 class="mt-2">Создать аккаунт</h3>
                    <p class="text-muted">Присоединяйтесь к CarRental</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"><i class="bi bi-envelope"></i> Email</label>
                            <input asp-for="Email" class="form-control" placeholder="example@mail.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"><i class="bi bi-lock"></i> Пароль</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="минимум 4 символа" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label"><i class="bi bi-check-circle"></i> Подтверждение пароля</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="повторите пароль" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Зарегистрироваться</button>
                    </form>
                    <div class="text-center mt-4">
                        <p>Уже есть аккаунт? <a asp-action="Login" class="auth-link">Войти</a></p>
                        <a href="/" class="auth-link">← Вернуться на главную</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>