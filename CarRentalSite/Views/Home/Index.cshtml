@model IEnumerable<CarRentalSite.Models.Car>
@{
    ViewData["Title"] = "Аренда автомобилей";
}

<!-- Герой-секция (можно оставить) -->
<div class="hero-section">
    <div class="container">
        <h1>CarRental</h1>
        <p class="lead">Арендуйте автомобиль мечты по выгодным ценам</p>
        <a href="/Cars" class="btn btn-hero mt-3">Выбрать автомобиль →</a>
    </div>
</div>

<div class="container">
    <!-- Преимущества (оставляем) -->
    <div class="row text-center mb-5">
        <div class="col-md-4 mb-4">
            <div class="card h-100 p-4">
                <i class="bi bi-shield-check" style="font-size: 3rem; color: #dc3545;"></i>
                <h4 class="mt-3">Надёжность</h4>
                <p>Все автомобили проходят регулярное техобслуживание.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 p-4">
                <i class="bi bi-cash-stack" style="font-size: 3rem; color: #dc3545;"></i>
                <h4 class="mt-3">Доступные цены</h4>
                <p>Прозрачные тарифы без скрытых платежей.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 p-4">
                <i class="bi bi-headset" style="font-size: 3rem; color: #dc3545;"></i>
                <h4 class="mt-3">Поддержка 24/7</h4>
                <p>Круглосуточная помощь на дороге.</p>
            </div>
        </div>
    </div>

    <!-- Карусель всех автомобилей -->
    <div class="row mb-4">
        <div class="col text-center">
            <h2 class="display-6">Наш автопарк</h2>
            <hr class="w-25 mx-auto" style="height: 3px; background-color: #dc3545;">
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div id="carouselCars" class="carousel slide carousel-fade shadow-lg rounded-4 overflow-hidden" data-bs-ride="carousel" data-bs-interval="3000">
            <div class="carousel-indicators">
                @for (int i = 0; i < Model.Count(); i++)
                {
                    <button type="button" data-bs-target="#carouselCars" data-bs-slide-to="@i" class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
                }
            </div>
            <div class="carousel-inner">
                @foreach (var car in Model.Select((value, index) => new { value, index }))
                {
                    <div class="carousel-item @(car.index == 0 ? "active" : "")">
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(car.value.ImageUrl) ? "/images/default-car.jpg" : car.value.ImageUrl)"
                                 class="d-block w-100"
                                 alt="@car.value.Brand @car.value.Model"
                                 style="height: 500px; object-fit: cover;">
                            <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded-3 p-3">
                                <h3>@car.value.Brand @car.value.Model (@car.value.Year)</h3>
                                <p>@car.value.Description</p>
                                <p class="fs-4 fw-bold text-danger">@car.value.PricePerDay ₽ / день</p>
                                @if (User.Identity.IsAuthenticated)
                                {
                                    <a asp-controller="Rentals" asp-action="Create" asp-route-carId="@car.value.Id" class="btn btn-danger rounded-pill px-4">
                                        <i class="bi bi-calendar-check"></i> Забронировать
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light rounded-pill px-4">
                                        <i class="bi bi-box-arrow-in-right"></i> Войти для брони
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#carouselCars" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselCars" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">Нет доступных автомобилей.</div>
    }

    <!-- Призыв к действию -->
    <div class="row mt-5 mb-5">
        <div class="col text-center bg-gradient-red text-white p-5 rounded-4">
            <h2>Готовы отправиться в путь?</h2>
            <p class="lead">Забронируйте автомобиль прямо сейчас и получите скидку 10% на первый заказ</p>
            <a href="/Cars" class="btn btn-light btn-lg mt-2">Все автомобили</a>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}